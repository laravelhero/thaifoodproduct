---
import { withBase } from '../lib/url.js';
const { category } = Astro.props;
const img = category.image?.src;
const childCount = category.children?.length || 0;
---
<a
  href={withBase(`/products/${category.slug}`)}
  class="group relative block overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-thai-ink/5 transition hover:shadow-xl hover:-translate-y-1"
>
  <div class="aspect-[4/3] overflow-hidden bg-thai-cream">
    {img ? (
      <img
        src={img}
        alt={category.name}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
      />
    ) : (
      <div class="grid h-full w-full place-items-center text-5xl">🍽️</div>
    )}
  </div>
  <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/75 via-black/30 to-transparent p-4 pt-10">
    <h3 class="font-display text-xl font-bold text-white drop-shadow">{category.name}</h3>
    <p class="text-sm text-thai-gold">
      {category.count} {category.count === 1 ? 'product' : 'products'}
      {childCount > 0 && ` · ${childCount} sub-categories`}
    </p>
  </div>
  <span class="absolute right-3 top-3 rounded-full bg-thai-gold px-3 py-1 text-xs font-bold text-thai-red opacity-0 transition group-hover:opacity-100">
    Explore →
  </span>
</a>
