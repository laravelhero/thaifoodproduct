---
import { getCategoryTree } from '../lib/woo.js';

const tree = await getCategoryTree();
const current = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/products', label: 'Products', hasMenu: true },
  { href: '/export', label: 'Export' },
  { href: '/contact#media', label: 'Media' },
  { href: '/contact', label: 'Contact Us' },
];

const isActive = (href) =>
  href === '/' ? current === '/' : current.startsWith(href.split('#')[0]);
---

<header class="sticky top-0 z-50 bg-thai-red text-thai-cream shadow-lg" x-data="{ mobile: false }">
  <div class="mx-auto max-w-7xl px-4">
    <div class="flex items-center justify-between h-20">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <span class="grid place-items-center w-11 h-11 rounded-full bg-thai-gold text-thai-red font-display font-extrabold text-xl shadow ring-2 ring-thai-gold/40">
          T
        </span>
        <span class="leading-tight">
          <span class="block font-display font-bold text-base sm:text-lg">International Thai Food</span>
          <span class="block text-[11px] tracking-wide text-thai-gold italic">Pure Taste with Real Quality</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) =>
          link.hasMenu ? (
            <div class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
              <a
                href={link.href}
                class:list={[
                  'inline-flex items-center gap-1 px-4 py-2 rounded-md font-medium transition hover:bg-thai-red-dark',
                  isActive(link.href) && 'bg-thai-red-dark text-thai-gold',
                ]}
              >
                {link.label}
                <svg class="w-3.5 h-3.5 transition" :class="open && 'rotate-180'" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
              </a>

              <!-- Category mega-menu -->
              <div
                x-show="open"
                x-transition.opacity
                x-cloak
                class="absolute left-1/2 -translate-x-1/2 mt-0 pt-3 w-[34rem]"
                style="display:none"
              >
                <div class="rounded-xl bg-thai-cream text-thai-ink shadow-2xl ring-1 ring-thai-red/10 p-4">
                  <a href="/products/all" class="mb-2 flex items-center justify-between rounded-lg bg-thai-red px-3 py-2 font-semibold text-thai-cream transition hover:bg-thai-red-dark">
                    <span>All Products</span>
                    <span aria-hidden="true">→</span>
                  </a>
                  <div class="grid grid-cols-2 gap-1">
                  {tree.map((cat) => (
                    <a href={`/products/${cat.slug}`} class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-thai-red hover:text-thai-cream transition font-semibold">
                      <span>{cat.name}</span>
                      <span class="text-xs opacity-60">{cat.count}</span>
                    </a>
                  ))}
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'px-4 py-2 rounded-md font-medium transition hover:bg-thai-red-dark',
                isActive(link.href) && 'bg-thai-red-dark text-thai-gold',
              ]}
            >
              {link.label}
            </a>
          )
        )}
      </nav>

      <!-- Mobile toggle -->
      <button class="lg:hidden p-2 rounded-md hover:bg-thai-red-dark" @click="mobile = !mobile" aria-label="Toggle menu">
        <svg x-show="!mobile" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg x-show="mobile" x-cloak class="w-7 h-7" style="display:none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div x-show="mobile" x-transition x-cloak class="lg:hidden bg-thai-red-dark border-t border-thai-cream/10" style="display:none">
    <nav class="px-4 py-3 space-y-1">
      <a href="/" class="block px-3 py-2 rounded-md hover:bg-thai-red font-medium">Home</a>
      <a href="/about" class="block px-3 py-2 rounded-md hover:bg-thai-red font-medium">About</a>
      <div x-data="{ sub: false }">
        <button @click="sub = !sub" class="w-full flex items-center justify-between px-3 py-2 rounded-md hover:bg-thai-red font-medium">
          Products
          <svg class="w-4 h-4" :class="sub && 'rotate-180'" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
        </button>
        <div x-show="sub" x-cloak class="pl-3 mt-1 space-y-0.5 border-l-2 border-thai-gold/40 ml-3" style="display:none">
          <a href="/products/all" class="block px-3 py-1.5 text-sm font-semibold text-thai-gold">All Products</a>
          <a href="/products" class="block px-3 py-1.5 text-sm text-thai-gold">All Categories</a>
          {tree.map((cat) => (
            <a href={`/products/${cat.slug}`} class="flex justify-between px-3 py-1.5 text-sm hover:text-thai-gold">
              <span>{cat.name}</span><span class="opacity-60">{cat.count}</span>
            </a>
          ))}
        </div>
      </div>
      <a href="/export" class="block px-3 py-2 rounded-md hover:bg-thai-red font-medium">Export</a>
      <a href="/contact#media" class="block px-3 py-2 rounded-md hover:bg-thai-red font-medium">Media</a>
      <a href="/contact" class="block px-3 py-2 rounded-md hover:bg-thai-red font-medium">Contact Us</a>
    </nav>
  </div>
</header>

<style>
  [x-cloak] { display: none !important; }
</style>
