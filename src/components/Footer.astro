---
import { getCategoryTree } from '../lib/woo.js';
const tree = await getCategoryTree();
const year = new Date().getFullYear();
---

<footer class="bg-thai-ink text-thai-cream/80">
  <div class="mx-auto max-w-7xl px-4 py-12 grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4 md:gap-10">
    <div class="md:col-span-1">
      <div class="mb-3">
        <img src="/images/logo.png" alt="ITFBL — International Thai Food and Beverage Limited" width="370" height="173" class="h-16 w-auto rounded-lg bg-white px-3 py-2" />
      </div>
      <p class="text-sm italic text-thai-gold/90">"Pure Taste with Real Quality"</p>
      <p class="mt-3 text-sm leading-relaxed">Authentic Thai cookies, biscuits, ready mixes and pickles — crafted for the world.</p>
    </div>

    <div>
      <h4 class="font-display text-thai-gold font-semibold mb-3">Products</h4>
      <ul class="space-y-1.5 text-sm">
        {tree.slice(0, 6).map((c) => (
          <li><a href={`/products/${c.slug}`} class="hover:text-thai-gold transition">{c.name}</a></li>
        ))}
        <li><a href="/products" class="hover:text-thai-gold transition font-medium">View all →</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-display text-thai-gold font-semibold mb-3">Company</h4>
      <ul class="space-y-1.5 text-sm">
        <li><a href="/about" class="hover:text-thai-gold transition">About Us</a></li>
        <li><a href="/export" class="hover:text-thai-gold transition">Export</a></li>
        <li><a href="/contact#media" class="hover:text-thai-gold transition">Media</a></li>
        <li><a href="/contact" class="hover:text-thai-gold transition">Contact Us</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-display text-thai-gold font-semibold mb-3">Get in Touch</h4>
      <ul class="space-y-2 text-sm">
        <li class="flex gap-2"><span>📍</span><span>748, BFIDC Road, Kalurghat Heavy I/A, Chandgaon, Chittagong, Bangladesh</span></li>
        <li class="flex gap-2"><span>📞</span><a href="tel:+8802334471619" class="hover:text-thai-gold">+880 2334471619</a></li>
        <li class="flex gap-2"><span>✉️</span><a href="mailto:info@bd-itfbl.com" class="hover:text-thai-gold">info@bd-itfbl.com</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-thai-cream/10">
    <div class="mx-auto max-w-7xl px-4 py-4 text-center text-xs text-thai-cream/60">
      © {year} International Thai Food and Beverage Limited. All rights reserved.
    </div>
  </div>
</footer>
