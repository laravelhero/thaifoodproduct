---
import { withBase } from '../lib/url.js';

const { product } = Astro.props;
const img = product.images?.[0]?.thumbnail || product.images?.[0]?.src;
const cat = product.categories?.[0]?.name || product.catNames?.[0];
const href = withBase(`/product/${product.slug}`);
---
<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-thai-ink/5 transition hover:-translate-y-1 hover:shadow-xl"
>
  <div class="relative aspect-square overflow-hidden bg-thai-cream">
    {img ? (
      <img
        src={img}
        alt={product.name}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="grid h-full w-full place-items-center text-5xl">🍪</div>
    )}
    {cat && (
      <span class="absolute left-3 top-3 rounded-full bg-thai-green/90 px-2.5 py-1 text-[11px] font-semibold text-white">
        {cat}
      </span>
    )}
  </div>

  <div class="flex flex-1 flex-col p-4">
    <h3 class="font-display text-lg font-bold leading-snug text-thai-red">{product.name}</h3>
    <span class="mt-auto pt-3 text-sm font-semibold text-thai-green transition group-hover:text-thai-red">
      View Details →
    </span>
  </div>
</a>
