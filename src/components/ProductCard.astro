---
const { product } = Astro.props;
const img = product.images?.[0]?.src;
const cat = product.categories?.[0];
---
<article
  x-data="{ open: false }"
  class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-thai-ink/5 transition hover:shadow-xl"
>
  <div class="relative aspect-square overflow-hidden bg-thai-cream">
    {img ? (
      <img
        src={img}
        alt={product.name}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="grid h-full w-full place-items-center text-5xl">🍪</div>
    )}
    {cat && (
      <span class="absolute left-3 top-3 rounded-full bg-thai-green/90 px-2.5 py-1 text-[11px] font-semibold text-white">
        {cat.name}
      </span>
    )}
  </div>

  <div class="flex flex-1 flex-col p-4">
    <h3 class="font-display text-lg font-bold leading-snug text-thai-red">{product.name}</h3>

    {product.short_description && (
      <div
        class="prose-spec mt-2 text-thai-ink/75"
        x-show="open"
        x-transition
        x-cloak
        style="display:none"
        set:html={product.short_description}
      />
    )}

    <div class="mt-auto pt-3">
      {product.short_description ? (
        <button
          @click="open = !open"
          class="text-sm font-semibold text-thai-green hover:text-thai-red transition"
        >
          <span x-show="!open">View More →</span>
          <span x-show="open" x-cloak style="display:none">Show Less ↑</span>
        </button>
      ) : (
        <a href={product.permalink} target="_blank" rel="noopener" class="text-sm font-semibold text-thai-green hover:text-thai-red transition">View More →</a>
      )}
    </div>
  </div>
</article>
