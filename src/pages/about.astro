---
import Layout from '../layouts/Layout.astro';
import HeroBackdrop from '../components/HeroBackdrop.astro';

const pillars = [
  {
    icon: '🌾',
    title: 'Our Heritage',
    tagline: 'Bringing Good Products to the World',
    text: 'From a modest beginning, we have grown into a well-known food manufacturer in Bangladesh — sharing our passion for making good foods with customers everywhere.',
  },
  {
    icon: '🎯',
    title: 'Our Mission',
    tagline: 'Delivering Excellence Worldwide',
    text: 'To deliver excellence worldwide through full technical knowledge and a relentless focus on health, safety and quality in every product we make.',
  },
  {
    icon: '💎',
    title: 'Our Values',
    tagline: 'Quality · Tradition · Integrity',
    text: 'Quality, Tradition and Integrity are the foundation of our brand — the principles behind every batch we produce and every shipment we send.',
  },
];
---

<Layout title="About Us — International Thai Food and Beverage">
  <section class="relative overflow-hidden bg-thai-red text-thai-cream">
    <HeroBackdrop />
    <div class="relative mx-auto max-w-7xl px-4 py-16 text-center">
      <h1 class="font-display text-4xl font-extrabold sm:text-5xl">About Us</h1>
      <p class="mx-auto mt-3 max-w-2xl font-display text-lg italic text-thai-gold">
        Pure Quality for Real Taste.
      </p>
    </div>
    <div class="h-1.5 w-full bg-gradient-to-r from-thai-gold via-thai-gold-soft to-thai-gold"></div>
  </section>

  <!-- Heritage / Mission / Values -->
  <section class="mx-auto max-w-7xl px-4 py-16">
    <div class="grid gap-8 md:grid-cols-3">
      {pillars.map((p) => (
        <article class="flex flex-col rounded-2xl bg-white p-8 shadow-md ring-1 ring-thai-ink/5 transition hover:-translate-y-1 hover:shadow-xl">
          <div class="text-4xl">{p.icon}</div>
          <h2 class="mt-3 font-display text-2xl font-bold text-thai-red">{p.title}</h2>
          <p class="mt-1 font-display text-sm italic text-thai-green">{p.tagline}</p>
          <p class="mt-3 text-thai-ink/75 leading-relaxed">{p.text}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Our Story: quote left, brand panel right -->
  <section class="bg-thai-cream">
    <div class="mx-auto max-w-7xl px-4 py-16">
      <div class="grid items-stretch gap-8 lg:grid-cols-2">
        <!-- Quote / story -->
        <div class="relative rounded-2xl bg-white p-8 shadow-md ring-1 ring-thai-ink/5 sm:p-10">
          <span class="font-display text-6xl leading-none text-thai-gold">&ldquo;</span>
          <div class="-mt-4 space-y-4 text-thai-ink/80 leading-relaxed">
            <p>
              From a modest beginning, <strong>International Thai Food and Beverage Ltd.</strong>
              is a well-known food manufacturer company in Bangladesh. From our produced
              products, one can easily understand that we are not less than the status of a
              top-class food products manufacturer — through our full technical knowledge and
              performance in the realms of health and safety in many countries around the world.
            </p>
            <p>
              We hope you enjoy our products as much as we enjoy offering them to you. If you
              have any questions, please don't hesitate to
              <a href="/contact" class="font-semibold text-thai-red hover:text-thai-red-dark">contact us</a>.
            </p>
            <p>We believe in — <strong class="text-thai-red">"Pure Quality for Real Taste"</strong>.</p>
          </div>
          <p class="mt-6 font-display font-bold text-thai-ink">International Thai Food and Beverage Ltd.</p>
        </div>

        <!-- Brand panel -->
        <div class="flex flex-col items-center justify-center rounded-2xl bg-thai-red p-10 text-center text-thai-cream shadow-md">
          <span class="grid h-16 w-16 place-items-center rounded-full bg-thai-gold font-display text-3xl font-extrabold text-thai-red shadow ring-4 ring-thai-gold/30">T</span>
          <h2 class="mt-6 font-display text-3xl font-extrabold sm:text-4xl">International Thai Food and Beverage Ltd.</h2>
          <p class="mt-3 font-display text-lg italic text-thai-gold">Pure Quality for Real Taste</p>
          <a href="/products" class="mt-8 inline-block rounded-full bg-thai-gold px-7 py-3 font-semibold text-thai-red shadow transition hover:scale-105 hover:bg-thai-gold-soft">
            Explore Our Products
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
